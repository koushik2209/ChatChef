# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Supabase, Neon, Railway, or local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/chatchef?schema=public"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# Dashboard origin for CORS — set to production URL when deploying
DASHBOARD_URL=http://localhost:5173

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ── Gupshup WhatsApp API ──────────────────────────────────────────────────────
# Find these at app.gupshup.io → your app → Settings
GUPSHUP_API_KEY=your_gupshup_api_key
GUPSHUP_APP_NAME=your_gupshup_app_name

# The WhatsApp number registered on your Gupshup app — no + prefix
# Used as the outgoing message source AND to route incoming messages:
#   messages received on this number  → seller onboarding / menu management
#   messages received on other numbers → customer ordering flow
CHATCHEF_NUMBER=91xxxxxxxxxx
