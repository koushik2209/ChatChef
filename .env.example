# PostgreSQL — e.g. from Supabase, Neon, or a local Postgres instance
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/chatchef?schema=public"

# Server
PORT=3000

# Dashboard origin (used for CORS — set to production URL in prod)
DASHBOARD_URL=http://localhost:5173

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Meta WhatsApp Cloud API
# Found at developers.facebook.com → your app → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=         # e.g. 123456789012345
WHATSAPP_ACCESS_TOKEN=            # Permanent token from System User
WHATSAPP_VERIFY_TOKEN=            # Any random string you choose (must match webhook config)
WHATSAPP_API_VERSION=v19.0
